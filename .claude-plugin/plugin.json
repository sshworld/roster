{
  "name": "roster",
  "version": "1.0.1",
  "description": "Static auditor for Claude Code agent rosters — overlap, harness gaps, routing, cost — with a resident drift guard.",
  "author": {
    "name": "sshworld",
    "url": "https://github.com/sshworld"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/roster-drift.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/roster-warn.sh"
          }
        ]
      }
    ]
  }
}
